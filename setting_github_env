# 1. Create the Staging and Production environments
gh api -X PUT /repos/:owner/:repo/environments/Staging
gh api -X PUT /repos/:owner/:repo/environments/Production

# 2. Set Repository-Wide Variables (Global)
gh variable set AWS_REGION --body "us-east-1"
gh variable set AWS_ROLE_ARN --body "arn:aws:iam::512431263418:role/lambda-ci-cd-gt-action-ServiceAccountRole"

# 3. Set Staging Variables
gh variable set FUNCTION_NAME --env Staging --body "lambda-ci-cd-gt-action-staging"
gh variable set URL --env Staging --body "https://arn:aws:lambda:us-east-1:512431263418:function:lambda-ci-cd-gt-action-staging"

# 4. Set Production Variables
gh variable set FUNCTION_NAME --env Production --body "lambda-ci-cd-gt-action-production"
gh variable set URL --env Production --body "https://arn:aws:lambda:us-east-1:512431263418:function:lambda-ci-cd-gt-action-production"
